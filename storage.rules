rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // ── Public read for all files ──────────────────────────────
    // Product images etc. need to be publicly accessible
    match /{allPaths=**} {
      allow read: if true;
    }

    // ── Product images: admin-only uploads with validation ─────
    match /products/{fileName} {
      allow write: if request.auth != null
                   && exists(/databases/(default)/documents/roles/$(request.auth.uid))
                   && get(/databases/(default)/documents/roles/$(request.auth.uid)).data.role == 'admin'
                   // Only allow image file types
                   && request.resource.contentType.matches('image/(jpeg|png|webp|gif)')
                   // Max file size: 5MB
                   && request.resource.size < 5 * 1024 * 1024;
    }

    // ── Deny all other writes ──────────────────────────────────
    match /{allPaths=**} {
      allow write: if false;
    }
  }
}
